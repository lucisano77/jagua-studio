{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "backend/api/**/*.mjs",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/orders", "dest": "/backend/api/orders.mjs" },
    { "src": "/(.*)", "dest": "/frontend/$1" }
  ]
}